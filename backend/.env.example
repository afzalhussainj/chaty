# Application
APP_NAME=university-chatbot-api
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging (INFO, DEBUG, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_JSON=false

# Database (PostgreSQL + pgvector; use postgresql+psycopg driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chaty
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Redis (cache, Celery broker)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Auth (later phases)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (later phases)
OPENAI_API_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
