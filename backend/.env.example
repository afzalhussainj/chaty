# Copy to .env and adjust. Never commit real secrets.

# --- Core ---
APP_ENV=development
# development | staging | production | test
DEBUG=false
LOG_LEVEL=INFO
# Set true in production for log aggregators (JSON lines to stdout)
LOG_JSON=false

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chaty

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Auth (required strong secret when APP_ENV=production) ---
JWT_SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- OpenAI (chat + embeddings) ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Public chat (unauthenticated) ---
PUBLIC_CHAT_ENABLED=true
# slowapi limit string, e.g. 30/minute, 100/hour
PUBLIC_CHAT_RATE_LIMIT=30/minute

# --- HTTP clients ---
CRAWL_HTTP_TIMEOUT_S=45
CRAWL_HTTP_MAX_RETRIES=3
CRAWL_HTTP_RETRY_BACKOFF_S=0.5
EXTRACTION_HTTP_TIMEOUT_S=120
EXTRACTION_HTTP_MAX_RETRIES=2

# --- Health ---
# When true, readiness checks Celery workers via inspect (extra latency; needs workers up)
HEALTH_CHECK_CELERY_WORKERS=false

# --- CORS (comma-separated origins for browser clients) ---
CORS_ORIGINS=http://localhost:3000
