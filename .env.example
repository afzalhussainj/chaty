# Root-level environment file for Docker Compose (copy to `.env`).
# Compose substitutes these variables into `docker-compose.yml` automatically.

# --- Required for chat, embeddings, and indexing ---
OPENAI_API_KEY=

# --- Auth (change for anything beyond local dev) ---
JWT_SECRET_KEY=dev-change-me

# --- Optional: first-run super admin (created on API startup if unset email does not exist) ---
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisPassword123

# --- OpenAI model overrides (optional) ---
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Public campus chat API ---
# PUBLIC_CHAT_ENABLED=true
